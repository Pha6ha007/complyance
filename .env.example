# Environment
NODE_ENV="development" # production on Railway

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/complyance?schema=public"

# Auth
NEXTAUTH_SECRET="your-secret-here" # Generate: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000" # Production: https://app.complyance.io
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# AI
ANTHROPIC_API_KEY=""

# Payments (Paddle)
PADDLE_API_KEY=""
PADDLE_WEBHOOK_SECRET=""
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=""
NEXT_PUBLIC_PADDLE_ENV="sandbox" # Production: production

# Storage (AWS S3)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET="complyance-docs" # Production bucket name
AWS_REGION="eu-central-1"

# Email (Resend)
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@complyance.io" # Production sender email

# Monitoring
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN="" # Optional - uses SENTRY_DSN if not set
SENTRY_ORG="" # Optional - for Sentry build-time configuration
SENTRY_PROJECT="" # Optional - for Sentry build-time configuration
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com" # Optional - defaults to PostHog cloud

# App URLs
NEXT_PUBLIC_APP_URL="http://localhost:3000" # Production: https://app.complyance.io

# Redis (for BullMQ worker)
REDIS_URL="redis://localhost:6379"

# Admin (founder email for admin panel access)
ADMIN_EMAIL="" # Your email for admin panel access

# Cron (for scheduled tasks authentication)
CRON_SECRET="" # Random secret for cron endpoint authentication

# Rate Limiting (optional - defaults shown)
RATE_LIMIT_MAX="100" # Max requests per window
RATE_LIMIT_WINDOW="60000" # Window in milliseconds (1 minute)
